{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mnemos",
  "version": "0.1.0",
  "identifier": "com.sd.mnemos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mnemos",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "category": "Productivity",
    "shortDescription": "Notes from you and your agents.",
    "longDescription": "Mnemos is a desktop note-taking app with an infinite Miro-style canvas. Organize notes as categories and integrate read-only with Engram memory for AI-generated context.",
    "copyright": "Copyright 2026",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
